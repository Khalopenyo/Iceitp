# Backend
DATABASE_URL=postgres://conf:confpass@localhost:5434/confdb?sslmode=disable
JWT_SECRET=change_me_super_secret
PORT=8080
GIN_MODE=release
ACCESS_TOKEN_TTL=12h
CORS_ORIGINS=http://localhost:5173
# TRUSTED_PROXIES=127.0.0.1,::1
PHONE_AUTH_CODE_TTL=10m
PHONE_AUTH_RESEND_COOLDOWN=60s
PHONE_AUTH_MAX_ATTEMPTS=5
FILE_STORAGE_ROOT=./storage

# GreenSMS auth delivery
# GREENSMS_CHANNEL=sms uses /sms/send with approved sender + approved template.
# GREENSMS_CHANNEL=telegram uses /telegram/send and sends only the numeric code.
GREENSMS_API_URL=https://api3.greensms.ru
GREENSMS_TOKEN=
GREENSMS_USER=
GREENSMS_PASS=
GREENSMS_CHANNEL=sms
GREENSMS_FROM=
GREENSMS_TEXT_TEMPLATE=Ваш код подтверждения: %d
GREENSMS_TELEGRAM_TTL=3600
GREENSMS_TELEGRAM_CASCADE=
GREENSMS_TELEGRAM_CASCADE_TEXT=

# Frontend
# For local Vite development.
# In docker compose production frontend uses nginx proxy and can work without this value.
VITE_API_URL=http://localhost:8080
