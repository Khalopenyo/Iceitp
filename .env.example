# Backend
DATABASE_URL=postgres://conf:confpass@localhost:5434/confdb?sslmode=disable
JWT_SECRET=change_me_super_secret
PORT=8080
GIN_MODE=release
CORS_ORIGINS=http://localhost:5173
# TRUSTED_PROXIES=127.0.0.1,::1
PHONE_AUTH_CODE_TTL=10m
PHONE_AUTH_RESEND_COOLDOWN=60s
PHONE_AUTH_MAX_ATTEMPTS=5

# GreenSMS SMS auth
# Uses official API endpoint https://api3.greensms.ru/sms/send
# GreenSMS may require a pre-approved sender shortname and template text for production SMS.
GREENSMS_API_URL=https://api3.greensms.ru
GREENSMS_TOKEN=
GREENSMS_USER=
GREENSMS_PASS=
GREENSMS_FROM=
GREENSMS_TEXT_TEMPLATE=Код входа в платформу конференции: %s

# Antiplagiat production overrides
# If set, these values override the database config at runtime.
# ANTIPLAGIAT_SITE_URL=https://your-company.antiplagiat.ru
# ANTIPLAGIAT_WSDL_URL=https://api.antiplagiat.ru:44902/apiCorp?wsdl
# ANTIPLAGIAT_API_LOGIN=api-user@example.com
# ANTIPLAGIAT_API_PASSWORD=change_me
# ANTIPLAGIAT_ENABLED=true

# Development-only helper. Never enable in production.
# ANTIPLAGIAT_BOOTSTRAP_TEST_CONFIG=false
# ANTIPLAGIAT_WORKER_CONCURRENCY=1
# ANTIPLAGIAT_WORKER_ID=conferenceplatforma-antiplagiat

# Frontend
# For local Vite development.
# In docker compose production frontend uses nginx proxy and can work without this value.
VITE_API_URL=http://localhost:8080
