# Public app URL used in password-reset links.
# Until a domain appears, keep the raw server IP over plain HTTP.
APP_BASE_URL=http://SERVER_IP

# Frontend is served by the frontend container on this host port.
FRONTEND_PORT=80

# Backend
JWT_SECRET=replace_with_a_long_random_secret
GIN_MODE=release
CORS_ORIGINS=http://SERVER_IP
# TRUSTED_PROXIES=127.0.0.1,::1
PASSWORD_RESET_TTL=2h
PHONE_AUTH_CODE_TTL=10m
PHONE_AUTH_RESEND_COOLDOWN=60s
PHONE_AUTH_MAX_ATTEMPTS=5

# GreenSMS SMS auth.
# Fill either GREENSMS_TOKEN or GREENSMS_USER/GREENSMS_PASS.
# GREENSMS_FROM should be a pre-approved sender shortname.
# GREENSMS_TEXT_TEMPLATE should match your approved SMS template if account is template-only.
GREENSMS_API_URL=https://api3.greensms.ru
GREENSMS_TOKEN=
GREENSMS_USER=
GREENSMS_PASS=
GREENSMS_FROM=
GREENSMS_TEXT_TEMPLATE=Код подтверждения в платформе конференции: %s

# SMTP for real password-reset emails.
# If left empty, reset links will only be written to backend logs.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Antiplagiat production overrides
ANTIPLAGIAT_SITE_URL=
ANTIPLAGIAT_WSDL_URL=
ANTIPLAGIAT_API_LOGIN=
ANTIPLAGIAT_API_PASSWORD=
ANTIPLAGIAT_ENABLED=
ANTIPLAGIAT_BOOTSTRAP_TEST_CONFIG=false
ANTIPLAGIAT_WORKER_CONCURRENCY=1
ANTIPLAGIAT_WORKER_ID=conferenceplatforma-antiplagiat
